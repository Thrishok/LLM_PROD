# Copy this file to .env and fill in real values. Never commit .env.

# --- Existing ---
GROQ_API_KEY=your-groq-key

# --- Google OAuth (from Google Cloud Console -> Credentials) ---
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Where Google redirects back after sign-in.
# Local dev:
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
# Production (set this on Render instead):
# OAUTH_REDIRECT_URI=https://llm-prod-0dph.onrender.com/auth/callback

# --- Session cookie signing ---
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# Set to "true" in production (HTTPS) so the session cookie is marked Secure.
COOKIE_SECURE=false

# --- Database ---
# Leave unset locally to use a SQLite file (app.db).
# On Render, set this to your Postgres "Internal Database URL".
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
